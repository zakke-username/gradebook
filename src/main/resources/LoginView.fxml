<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="458.0" prefWidth="341.0" spacing="16.0" style="-fx-background-color: #d2dce5; -fx-background-radius: 8;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.LoginController">

    <Label style="-fx-text-fill: black; -fx-font-weight: bold;" text="Kirjaudu sisään">
        <font>
            <Font name="System Bold" size="18.0" />
        </font>
        <VBox.margin>
            <Insets bottom="16" left="16" right="16" top="16" />
        </VBox.margin>
    </Label>

    <VBox spacing="8.0" style="-fx-background-color: #b6c8d4; -fx-background-radius: 8;">
        <Label style="-fx-text-fill: black;" text="Käyttäjänimi">
            <font>
                <Font name="System Bold" size="14.0" />
            </font>
            <VBox.margin>
                <Insets bottom="4" left="16" right="16" top="8" />
            </VBox.margin>
        </Label>
        <TextField fx:id="usernameField" promptText="Syötä käyttäjänimi" style="-fx-background-color: white; -fx-background-radius: 4; -fx-padding: 4 8;" />
        <VBox.margin>
            <Insets bottom="16" left="16" right="16" />
        </VBox.margin>
    </VBox>

    <VBox spacing="8.0" style="-fx-background-color: #b6c8d4; -fx-background-radius: 8;">
        <Label style="-fx-text-fill: black;" text="Salasana">
            <font>
                <Font name="System Bold" size="14.0" />
            </font>
            <VBox.margin>
                <Insets bottom="4" left="16" right="16" top="8" />
            </VBox.margin>
        </Label>
        <PasswordField fx:id="passwordField" promptText="Syötä salasana" style="-fx-background-color: white; -fx-background-radius: 4; -fx-padding: 4 8;" />
        <VBox.margin>
            <Insets bottom="16" left="16" right="16" />
        </VBox.margin>
    </VBox>

    <Button onAction="#handleLogin" style="-fx-background-color: #b6c8d4; -fx-font-weight: bold; -fx-text-fill: black; -fx-background-radius: 8; -fx-padding: 8 16; -fx-cursor: hand;" styleClass="hoverable" stylesheets="@style.css" text="Kirjaudu">
        <VBox.margin>
            <Insets bottom="16" left="16" right="16" top="8" />
        </VBox.margin>
    </Button>

    <Label fx:id="errorLabel" style="-fx-text-fill: red; -fx-font-weight: bold;" text="" />

</VBox>
